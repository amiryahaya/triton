# ============================================
# Go
# ============================================

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# Dependency directories
vendor/

# Build directories
bin/
dist/
# License + Report + Manage portal dist/ — generated by `make web`
pkg/licenseserver/ui/dist/*
!pkg/licenseserver/ui/dist/.gitkeep
pkg/server/ui/dist/*
!pkg/server/ui/dist/.gitkeep
pkg/manageserver/ui/dist/*
!pkg/manageserver/ui/dist/.gitkeep
!pkg/licenseserver/download/dist/
build/

# Go module cache (if vendoring)
/go/pkg/mod/

