# =============================================================================
# Triton Multi-Tenant Configuration — Example
# =============================================================================
# Copy this file to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#
# This file documents every env var consumed by the License Server, the Report
# Server (formerly "Triton Server"), and the Agent CLI when running in
# multi-tenant mode.
# =============================================================================


# -----------------------------------------------------------------------------
# License Server
# -----------------------------------------------------------------------------
# The license server is the source of truth for organizations, license keys,
# seat pools, and superadmin users. Superadmins log in here to manage orgs.

# Network
TRITON_LICENSE_SERVER_LISTEN=:8081

# Database (separate from the report server's database)
TRITON_LICENSE_SERVER_DB_URL=postgres://triton:triton@localhost:5434/triton_license?sslmode=disable

# Admin API key (legacy — used by service-to-service callers that aren't using
# the new shared key below). One or more comma-separated keys.
TRITON_LICENSE_SERVER_ADMIN_KEY=

# Ed25519 signing key for issued license tokens AND superadmin JWTs (hex-encoded)
# Generate: openssl rand -hex 32  (then derive Ed25519 keypair via tooling)
TRITON_LICENSE_SERVER_SIGNING_KEY=

# Bootstrap superadmin (only used on first startup when users table is empty)
TRITON_LICENSE_SERVER_ADMIN_EMAIL=admin@example.com
TRITON_LICENSE_SERVER_ADMIN_PASSWORD=

# TLS (production) — leave blank for plaintext local dev
TRITON_LICENSE_SERVER_TLS_CERT=
TRITON_LICENSE_SERVER_TLS_KEY=

# Where the license server stores agent installer binaries
TRITON_LICENSE_SERVER_BINARIES_DIR=/opt/triton/binaries


# -----------------------------------------------------------------------------
# Report Server (formerly "Triton Server")
# -----------------------------------------------------------------------------
# The report server collects scan reports from agents and aggregates them per
# org. Org users (org_admin, org_user) log in here to view their org's data.

# Network
REPORT_SERVER_LISTEN=:8080
REPORT_SERVER_PUBLIC_URL=https://reports.example.com

# Database (separate from the license server's database)
REPORT_SERVER_DB_URL=postgres://triton:triton@localhost:5434/triton?sslmode=disable

# Ed25519 signing key for the report server's own user JWTs (hex-encoded)
# Independent from the license server's key. Generate separately.
REPORT_SERVER_JWT_SIGNING_KEY=

# License server URL (report server validates license tokens against this)
REPORT_SERVER_LICENSE_SERVER_URL=http://localhost:8081

# Column encryption key for scan_data at rest (32 bytes / 64 hex chars)
# Generate: openssl rand -hex 32
REPORT_SERVER_DATA_ENCRYPTION_KEY=

# TLS (production)
REPORT_SERVER_TLS_CERT=
REPORT_SERVER_TLS_KEY=


# -----------------------------------------------------------------------------
# Service-to-Service Authentication
# -----------------------------------------------------------------------------
# Shared secret used by the license server to authenticate to the report
# server's org provisioning endpoint (POST /api/v1/admin/orgs). The same
# secret is configured on both servers.
#
# Generate: openssl rand -hex 32

LICENSE_TO_REPORT_SHARED_KEY=


# -----------------------------------------------------------------------------
# Email Delivery (Resend API)
# -----------------------------------------------------------------------------
# Used by the license server to send first-org-admin invites and (future)
# password reset emails. Get an API key from https://resend.com

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Triton Reports

# Where invite links point to (the report server's first-login URL)
# The license server includes this in the invite email body.
REPORT_SERVER_INVITE_URL_BASE=https://reports.example.com/login


# -----------------------------------------------------------------------------
# Agent CLI (per-machine)
# -----------------------------------------------------------------------------
# These are typically passed as flags, but can be set as env vars for
# scripted deployments.

# Mandatory for comprehensive scans, optional for quick scans
TRITON_LICENSE_KEY=

# Optional — if set, agent submits scan output to this report server after scanning
TRITON_REPORT_SERVER=
