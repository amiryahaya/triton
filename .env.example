# =============================================================================
# Triton Multi-Tenant Configuration — Example
# =============================================================================
# Copy this file to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#
# Or — for local development — skip the copy and generate a fresh .env
# with random credentials and a matching license token in one shot:
#
#   ./scripts/gen-dev-env.sh > .env
#
# Every variable marked REQUIRED must be set before `podman compose up`
# will start the stack — compose.yaml uses `${VAR:?error}` to fail fast
# on missing values so there are no dev-key fallbacks in production.
#
# This file documents every env var consumed by the License Server, the
# Report Server (formerly "Triton Server"), and the Agent CLI when
# running in multi-tenant mode.
# =============================================================================


# =============================================================================
# CONTAINER IMAGES
# =============================================================================
# By default compose.yaml pulls pre-built images from ghcr.io. Override
# these to pin a specific version or use locally-built images.
#
# Pin to a release:  TRITON_IMAGE=ghcr.io/amiryahaya/triton:v3.3.0
# Use local build:   TRITON_IMAGE=localhost/triton:local

TRITON_IMAGE=ghcr.io/amiryahaya/triton:latest
TRITON_LICENSE_SERVER_IMAGE=ghcr.io/amiryahaya/triton-license-server:latest


# =============================================================================
# LICENSE SERVER
# =============================================================================
# Source of truth for organizations, license keys, seat pools, and superadmin
# users. Superadmins log in here to manage orgs.

# Network
TRITON_LICENSE_SERVER_LISTEN=:8081

# Database (separate from the report server's database)
TRITON_LICENSE_SERVER_DB_URL=postgres://triton:triton@localhost:5435/triton_license?sslmode=disable

# REQUIRED — Admin API key for service-to-service callers and the admin UI.
# One or more comma-separated keys.
# Generate: openssl rand -hex 32
TRITON_LICENSE_SERVER_ADMIN_KEY=

# REQUIRED — Ed25519 private key (64 hex chars = 32-byte seed + 32-byte pubkey).
# Signs all issued license tokens AND superadmin JWTs.
# Generate via scripts/gen-dev-env.sh or:
#   openssl genpkey -algorithm ed25519 | openssl pkey -outform DER | tail -c 32 | xxd -p -c 64
#   (then append the public half — see scripts/gen-dev-env.sh for the full recipe)
TRITON_LICENSE_SERVER_SIGNING_KEY=

# Bootstrap superadmin (only used on first startup when users table is empty)
TRITON_LICENSE_SERVER_ADMIN_EMAIL=admin@example.com
TRITON_LICENSE_SERVER_ADMIN_PASSWORD=

# TLS (production) — leave blank for plaintext local dev
TRITON_LICENSE_SERVER_TLS_CERT=
TRITON_LICENSE_SERVER_TLS_KEY=

# Where the license server stores uploaded agent binaries (filesystem path)
TRITON_LICENSE_SERVER_BINARIES_DIR=/opt/triton/binaries

# Public URL of the license server itself (customer-facing). Required for
# one-liner install links (curl | sudo bash). When unset, the "Copy install
# command" button in the admin UI is disabled.
# Example: https://license.example.com
TRITON_LICENSE_SERVER_PUBLIC_URL=


# =============================================================================
# REPORT SERVER
# =============================================================================
# Collects scan reports from agents and aggregates them per org. Org users
# (org_admin, org_user) log in here to view their org's data.
#
# NOTE: The report server reads --db and --listen as CLI flags, not env vars.
# In compose, these are set in the `command:` field. Outside compose, pass them
# directly: triton server --db "postgres://..." --listen ":8080"

# REQUIRED — Ed25519 signing key for the report server's own user JWTs
# (hex-encoded). Independent from the license server's key.
# Generate: openssl rand -hex 32
REPORT_SERVER_JWT_SIGNING_KEY=

# REQUIRED — Ed25519 PUBLIC key (64 hex chars) used to verify incoming agent
# license tokens. This is the PUBLIC half of TRITON_LICENSE_SERVER_SIGNING_KEY —
# the last 32 bytes (64 hex chars) of that 64-byte private key blob.
# scripts/gen-dev-env.sh derives this automatically.
REPORT_SERVER_TENANT_PUBKEY=

# REQUIRED — Shared secret (must match TRITON_LICENSE_SERVER_REPORT_KEY).
# See "Service-to-Service Authentication" below.
REPORT_SERVER_SERVICE_KEY=

# AES-256-GCM key for encrypting scan result_json at rest (64 hex chars).
# When unset, scans are stored as plaintext JSONB.
# Generate: openssl rand -hex 32
REPORT_SERVER_DATA_ENCRYPTION_KEY=

# Link embedded in invite emails — points at the report server's login page.
REPORT_SERVER_INVITE_URL=http://localhost:8090/ui/#/login

# TLS (production) — passed as CLI flags, not env vars:
#   triton server --tls-cert /path/to/cert.pem --tls-key /path/to/key.pem

# --- JWT Session Cache (optional) ---
# Caches validated JWT sessions to skip DB lookups on every request.
# Size=0 disables the cache (with a log warning).
REPORT_SERVER_SESSION_CACHE_SIZE=10000
REPORT_SERVER_SESSION_CACHE_TTL=60s

# --- Login Rate Limiting (optional) ---
# Per-email lockout after too many failed login attempts.
REPORT_SERVER_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
REPORT_SERVER_LOGIN_RATE_LIMIT_WINDOW=15m
REPORT_SERVER_LOGIN_RATE_LIMIT_LOCKOUT=15m

# --- Request Rate Limiting (optional) ---
# Per-tenant request throttle on authenticated API routes.
REPORT_SERVER_REQUEST_RATE_LIMIT_MAX_REQUESTS=600
REPORT_SERVER_REQUEST_RATE_LIMIT_WINDOW=1m

# --- Resend Mailer (optional) ---
# Email delivery for org-user invites on the report server side.
# Get an API key from https://resend.com
REPORT_SERVER_RESEND_API_KEY=
REPORT_SERVER_RESEND_FROM_EMAIL=
REPORT_SERVER_RESEND_FROM_NAME=Triton Reports


# =============================================================================
# MANAGE SERVER (PR B1)
# =============================================================================
# Optional on-prem admin backend. Runs alongside the License + Report servers.
# B1 ships the HTTP shell (setup, auth, licence wiring). Scanner orchestration
# lands in B2, Vue UI in C. Bring up with:
#
#   podman compose --profile manage-server up -d
#
# The Manage Server uses its own database (triton_manage) on the shared
# postgres instance. scripts/init-db.sh creates it on first postgres startup.

# Override the image tag once B1 is released; defaults to locally-built.
# TRITON_MANAGE_SERVER_IMAGE=triton-manageserver:local

# REQUIRED — HS256 secret (hex, ≥32 bytes after decode) for signing
# Manage Server session JWTs. Independent from the other servers'
# signing keys — rotate to invalidate every Manage Server session.
# Generate: openssl rand -hex 32
TRITON_MANAGE_JWT_SIGNING_KEY=

# REQUIRED — Ed25519 PUBLIC key (hex, 32 bytes = 64 hex chars) used to
# verify licence tokens the Manage Server retrieves from the License
# Server during activation. Must match the public half of
# TRITON_LICENSE_SERVER_SIGNING_KEY (last 32 bytes of the private seed).
TRITON_MANAGE_LICENSE_SERVER_PUBKEY=

# Optional — Manage Server database URL. Default targets triton_manage
# on the compose-network postgres instance.
# TRITON_MANAGE_DB_URL=postgres://triton:triton@localhost:5435/triton_manage?sslmode=disable

# Optional — Manage Server session lifetime (Go duration). Default: 24h.
# TRITON_MANAGE_SESSION_TTL=24h

# --- Agent mTLS gateway (PR B2.2) ---
#
# Manage Server terminates agent mTLS on :8443 — the agent's bundle dials
# this address and submits scans + phone-home requests. The admin plane
# (:8082) handles operator UI + CRUD.
#
# Inside the container the listener defaults to :8443; the compose file
# maps 8443:8443 so agents on the same host can dial localhost:8443.
# To change the external listen address, override the container env var
# directly; the variables below only affect the URL baked into bundles
# and the server-leaf cert's SAN.

# Hostname baked into bundle.yaml so the agent knows where to dial. For
# real deployments set this to the DNS name agents will resolve; for
# local dev "localhost" is fine because Docker/Podman loopback-maps the
# port.
# MANAGE_GATEWAY_HOSTNAME=manage.example.com

# Scan orchestrator worker count (1-50). Bounds Postgres connection
# usage; 10 is a reasonable default for small fleets. Larger deployments
# can raise this up to 50 without exceeding the 50-worker cap.
# MANAGE_PARALLELISM=10

# Report Server URL + service key for Manage auto-enrol (fires once,
# right after /setup/license). Both must be set to fire auto-enrol;
# either alone is treated as unconfigured and skipped silently. When
# auto-enrol is skipped, admins can re-trigger manually via the admin
# API once both values are wired up.
# REPORT_URL=https://report.example.com
# REPORT_SERVICE_KEY=<hex64 — must match the Report server's REPORT_SERVER_SERVICE_KEY>


# =============================================================================
# SERVICE-TO-SERVICE AUTHENTICATION
# =============================================================================
# Shared secret used by the license server to authenticate to the report
# server's org provisioning endpoint (POST /api/v1/admin/orgs). Each side
# reads it under a DIFFERENT env var name — set BOTH to the SAME value.
#
# Generate: openssl rand -hex 32
#
#   License server reads:  TRITON_LICENSE_SERVER_REPORT_KEY
#   Report server reads:   REPORT_SERVER_SERVICE_KEY
#
# ⚠  These MUST be identical. A mismatch silently disables org provisioning.

# License server side — outbound credential when calling report server:
TRITON_LICENSE_SERVER_REPORT_KEY=

# Internal URL the license server uses to reach the report server.
# In compose this is the service name (http://triton:8080).
# Outside compose, use the real internal hostname.
TRITON_LICENSE_SERVER_REPORT_URL=http://triton:8080

# Customer-facing report server URL baked into generated agent.yaml files.
# Keep this distinct from the internal URL — the internal URL may be
# unreachable from outside the service network.
TRITON_LICENSE_SERVER_REPORT_PUBLIC_URL=http://localhost:8090


# =============================================================================
# EMAIL DELIVERY — LICENSE SERVER (Resend API)
# =============================================================================
# Used by the license server to send first-org-admin invites.
# NOTE: These use DIFFERENT env var names than the report server's
# Resend config above. If both services need to send email, you must
# set BOTH sets of variables.

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Triton Reports

# Login link included in invite email body. Points at the report server's
# first-login page. The license server reads this as REPORT_SERVER_INVITE_URL_BASE
# (note: the report server reads REPORT_SERVER_INVITE_URL — different name).
REPORT_SERVER_INVITE_URL_BASE=https://reports.example.com/ui/#/login


# =============================================================================
# AGENT CLI (per-machine)
# =============================================================================
# These are typically set in agent.yaml (next to the binary) or passed as
# CLI flags. Env vars are a fallback for scripted deployments.

# License token — required for standard/comprehensive profiles.
# Obtain from the license server admin UI → Licenses → Download agent.yaml.
TRITON_LICENSE_KEY=

# Enterprise license token for the report server's own CLI guard.
# In compose, this is the token the server uses to pass the FeatureServerMode
# gate. Mint one via the license server admin UI or scripts/gen-dev-env.sh.
# TRITON_LICENSE_KEY=<paste here>
